# Copy this file to `.env.local` (which is .gitignored) and fill in real values.
#
# Both values are publicly safe per mod.io's docs — the api_key is read-only
# and game_id is part of every mod URL. They go into the static bundle.

# mod.io game ID. Found at https://mod.io/g/<your-game>/admin/api
VITE_MODIO_GAME_ID=

# Read-only game api_key from the same admin page.
VITE_MODIO_API_KEY=

# 'live' or 'test'. Test environment is at *.test.mod.io and is wiped
# periodically. Defaults to 'live' if unset.
VITE_MODIO_ENV=live
