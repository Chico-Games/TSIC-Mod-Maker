{
  "name": "tsic-crafting-tool-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/sync-base-definitions.mjs && vite",
    "sync-defaults": "node scripts/sync-base-definitions.mjs",
    "build": "node scripts/sync-base-definitions.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "smoke": "node definitions-ui-smoke.mjs && node recipes-loot-ui-smoke.mjs",
    "smoke:def": "node definitions-ui-smoke.mjs",
    "smoke:loot": "node recipes-loot-ui-smoke.mjs",
    "data-smoke": "node data-smoke.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@leeoniya/ufuzzy": "^1.0.19",
    "@xyflow/react": "^12.3.5",
    "dagre": "^0.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
